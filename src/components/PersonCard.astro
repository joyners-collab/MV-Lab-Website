---
interface Props {
  name: string;
  role: string;
  photo?: string;
  bio?: string;
  email?: string;
  scholar?: string;
  orcid?: string;
  github?: string;
  website?: string;
}
const { name, role, photo, bio, email, scholar, orcid, github, website } = Astro.props;
---

<article class="group">
  <div class="relative aspect-[4/5] overflow-hidden bg-ink-800 mb-5 ring-1 ring-white/5">
    {photo ? (
      <img
        src={photo}
        alt={`Portrait of ${name}`}
        class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
        loading="lazy"
      />
    ) : (
      <!-- Placeholder when no photo -->
      <div class="w-full h-full flex items-center justify-center">
        <svg viewBox="0 0 100 100" class="w-1/3 h-1/3 text-bone-mute opacity-30">
          <circle cx="50" cy="36" r="18" fill="currentColor" />
          <path d="M14 92c4-22 22-32 36-32s32 10 36 32" fill="currentColor" />
        </svg>
      </div>
    )}
    <!-- subtle red glow on hover -->
    <div class="absolute inset-0 ring-0 ring-pulse/0 group-hover:ring-1 group-hover:ring-pulse/40 transition" />
  </div>

  <h3 class="font-display text-2xl text-bone leading-tight">{name}</h3>
  <p class="font-mono text-xs uppercase tracking-wider text-pulse mt-1">{role}</p>

  {bio && (
    <p class="mt-3 text-sm text-bone-dim leading-relaxed">{bio}</p>
  )}

  {(email || scholar || orcid || github || website) && (
    <ul class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-xs font-mono">
      {email   && <li><a href={`mailto:${email}`} class="text-bone-dim hover:text-pulse link-underline">email</a></li>}
      {website && <li><a href={website} class="text-bone-dim hover:text-pulse link-underline" target="_blank" rel="noopener">website</a></li>}
      {scholar && <li><a href={scholar} class="text-bone-dim hover:text-pulse link-underline" target="_blank" rel="noopener">scholar</a></li>}
      {orcid   && <li><a href={`https://orcid.org/${orcid}`} class="text-bone-dim hover:text-pulse link-underline" target="_blank" rel="noopener">orcid</a></li>}
      {github  && <li><a href={`https://github.com/${github}`} class="text-bone-dim hover:text-pulse link-underline" target="_blank" rel="noopener">github</a></li>}
    </ul>
  )}
</article>
