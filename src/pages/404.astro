---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found">
  <div class="container-site min-h-[60vh] flex flex-col justify-center py-24">
    <p class="eyebrow mb-4">Error 404</p>
    <h1 class="font-display text-5xl lg:text-7xl text-balance leading-none">
      Asystole.<br />
      <span class="text-pulse">No pulse here.</span>
    </h1>
    <p class="mt-6 max-w-md text-bone-dim leading-relaxed">
      The page you were looking for doesn't exist. Try one of the links above,
      or head back to the home page.
    </p>
    <p class="mt-10">
      <a
        href="/"
        class="inline-block font-mono text-sm uppercase tracking-wider px-6 py-3 border border-pulse text-pulse hover:bg-pulse hover:text-white transition-colors"
      >
        ← Home
      </a>
    </p>
  </div>
</Base>
