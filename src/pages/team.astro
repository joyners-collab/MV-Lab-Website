---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import PersonCard from '../components/PersonCard.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('people');
const current = all
  .filter(p => p.data.current)
  .sort((a, b) => a.data.order - b.data.order);
const alumni = all
  .filter(p => !p.data.current)
  .sort((a, b) => a.data.order - b.data.order);

// Group order on the page
const groupOrder = [
  'PI',
  'Team Member',
  'Postdoc',
  'Graduate Student',
  'Research Associate',
  'Undergraduate',
  'Staff',
] as const;

// Custom display labels per group
const groupLabels: Record<string, { single: string; plural: string }> = {
  'PI':                   { single: 'Principal Investigator', plural: 'Principal Investigators' },
  'Team Member':          { single: 'Team Member',            plural: 'Team Members' },
  'Postdoc':              { single: 'Postdoc',                plural: 'Postdocs' },
  'Graduate Student':     { single: 'Graduate Student',       plural: 'Graduate Students' },
  'Research Associate':   { single: 'Research Associate',     plural: 'Research Associates' },
  'Undergraduate':        { single: 'Undergraduate',          plural: 'Undergraduates' },
  'Staff':                { single: 'Staff',                  plural: 'Staff' },
};

const grouped = groupOrder.map(g => ({
  group: g,
  members: current.filter(p => p.data.group === g),
})).filter(g => g.members.length > 0);
---

<Base title="Team" description="The people of the MV Lab.">
  <Section
    tight
    eyebrow="Team"
    title="Meet the lab."
    lede="A small, growing group of physiologists, molecular biologists, and engineers united by a shared fascination with the heart."
  />

  <div class="container-site space-y-20 pb-24">
    {grouped.map((group) => {
      const label = groupLabels[group.group];
      const heading = group.members.length > 1 ? label.plural : label.single;
      return (
        <section>
          <h2 class="eyebrow mb-8">{heading}</h2>
          <div class="grid gap-10 sm:gap-12 sm:grid-cols-2 lg:grid-cols-3">
            {group.members.map((person) => (
              <PersonCard
                name={person.data.name}
                role={person.data.role}
                photo={person.data.photo}
                email={person.data.email}
                scholar={person.data.scholar}
                orcid={person.data.orcid}
                github={person.data.github}
                website={person.data.website}
                bio={person.body.replace(/^---[\s\S]*?---/, '').trim().slice(0, 280)}
              />
            ))}
          </div>
        </section>
      );
    })}

    <!-- Alumni section — always shown -->
    <section>
      <h2 class="eyebrow mb-8">Alumni</h2>
      {alumni.length > 0 ? (
        <ul class="space-y-4">
          {alumni.map((p) => (
            <li class="flex flex-wrap items-baseline gap-x-4 gap-y-1 py-3 border-b border-white/10">
              <span class="font-display text-lg text-bone">{p.data.name}</span>
              <span class="text-sm text-bone-mute font-mono">{p.data.role}</span>
              {p.data.joined && <span class="text-xs text-bone-mute font-mono ml-auto">{p.data.joined}</span>}
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-bone-dim italic">Past members of the lab will be listed here.</p>
      )}
    </section>
  </div>
</Base>