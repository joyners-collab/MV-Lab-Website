---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';

// ----------------------------------------------------------------
//  Edit testimonials by adding/removing items in this list.
//  Set `published: true` once you have real content to show one.
//  When all items are unpublished, a placeholder message shows instead.
// ----------------------------------------------------------------
const testimonials = [
  { published: false, quote: '', author: '', affiliation: '' },
  { published: false, quote: '', author: '', affiliation: '' },
];

// ----------------------------------------------------------------
//  Photo gallery — drop image files into public/outreach/ and add
//  their filenames here. Empty entries render as styled placeholders.
//  Set src to a real path like '/outreach/photo-1.jpg' when ready.
// ----------------------------------------------------------------
const galleryPhotos = [
  { src: '', alt: '' },
  { src: '', alt: '' },
  { src: '', alt: '' },
  { src: '', alt: '' },
  { src: '', alt: '' },
  { src: '', alt: '' },
];

// ----------------------------------------------------------------
//  BRIGHT-UP external website (the "visit our website here" link)
//  Set to the real URL when ready.
// ----------------------------------------------------------------
const brightupUrl = ''; // e.g. 'https://bright-up.example.org'

// Optional second image — landscape photo of students at the bench
// Drop a file at public/outreach/brightup-hero.jpg to enable it.
const brightupHero = '/outreach/brightup-hero.jpg';
const brightupBanner = '/outreach/brightup-banner.png';

const visibleTestimonials = testimonials.filter(t => t.published);
---

<Base title="Outreach" description="BRIGHT-UP and the MV Lab's commitment to science education and outreach.">

  <!-- Page header -->
  <Section
    tight
    eyebrow="Outreach"
    title="Beyond the bench."
    lede="We believe science belongs to everyone. The lab runs and contributes to programs that bring biomedical research to students, teachers, and the broader public."
  />

  <!-- BRIGHT-UP banner — full-bleed -->
  <div class="container-site pb-16 lg:pb-20">
    <div class="overflow-hidden ring-1 ring-white/5">
      <img
        src={brightupBanner}
        alt="BRIGHT-UP — Biomedical Research Internship for the Growth of High School Trainees from Underrepresented Populations"
        class="w-full h-auto block"
      />
    </div>
  </div>

  <!-- BRIGHT-UP hero (with photo + headline) -->
  <section class="container-site pb-12 lg:pb-16">
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-center">
      <!-- Image -->
      <div class="lg:col-span-7">
        <div class="relative aspect-[4/3] bg-ink-800 ring-1 ring-white/5 overflow-hidden">
          <img
            src={brightupHero}
            alt="BRIGHT-UP students at the bench"
            class="w-full h-full object-cover"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          />
          <div
            class="absolute inset-0 hidden items-center justify-center"
            style="background: radial-gradient(ellipse at center, rgba(216, 50, 60, 0.15), transparent 70%);"
          >
            <span class="font-mono text-xs uppercase tracking-widest2 text-bone-mute text-center px-4">
              Optional photo · drop file at public/outreach/brightup-hero.jpg
            </span>
          </div>
        </div>
      </div>

      <!-- Headline / tagline -->
      <div class="lg:col-span-5">
        <p class="eyebrow mb-4">Featured program</p>
        <h2 class="font-display text-4xl lg:text-5xl xl:text-6xl text-bone leading-[1.05] tracking-tight text-balance">
          Empowering the next generation of diverse scientific leaders.
        </h2>
      </div>
    </div>
  </section>

  <!-- Our Mission -->
  <Section eyebrow="Our mission" title="What BRIGHT-UP stands for.">
    <div class="max-w-prose space-y-6 text-lg text-bone leading-relaxed text-pretty">
      <p>
        To provide an outstanding and immersive educational experience to high
        school students from underserved communities, particularly those from
        low-income backgrounds and minority groups, who have historically faced
        underrepresentation in the field of science.
      </p>
      <p>
        Through the creation of an inclusive and nurturing environment, we are
        dedicated to offering our students the opportunity to explore science
        as a viable career path. Our ultimate goal is to empower the next
        generation of diverse scientific leaders who will play a pivotal role
        in advancing scientific knowledge and driving societal equity.
      </p>
      <p>
        BRIGHT-UP offers outstanding high school students from diverse racial
        and cultural backgrounds in the Seattle area the opportunity to join
        biomedical research labs at the University of Washington and explore
        science as a career path.
      </p>
      {brightupUrl ? (
        <p class="pt-4">
          
            href={brightupUrl}
            target="_blank"
            rel="noopener"
            class="inline-block font-mono text-sm uppercase tracking-wider text-pulse link-underline"
          >
            Visit the BRIGHT-UP website →
          </a>
        </p>
      ) : (
        <p class="pt-4 text-sm text-bone-mute italic">
          (Add the BRIGHT-UP website URL in src/pages/outreach.astro to enable the link.)
        </p>
      )}
    </div>
  </Section>

  <!-- Testimonials -->
  <Section eyebrow="Voices from the program" title="Testimonials.">
    {visibleTestimonials.length > 0 ? (
      <div class="grid gap-8 md:grid-cols-2 lg:gap-12">
        {visibleTestimonials.map((t) => (
          <figure class="border-l-2 border-pulse pl-6 py-2">
            <blockquote class="font-display text-xl lg:text-2xl text-bone leading-snug text-pretty">
              "{t.quote}"
            </blockquote>
            <figcaption class="mt-4 text-sm text-bone-dim">
              <span class="font-medium text-bone">{t.author}</span>
              {t.affiliation && (
                <span class="text-bone-mute"> · {t.affiliation}</span>
              )}
            </figcaption>
          </figure>
        ))}
      </div>
    ) : (
      <div class="border-l-2 border-pulse/40 pl-6 py-4">
        <p class="text-bone-dim italic max-w-prose leading-relaxed">
          Testimonials from past BRIGHT-UP participants will appear here.
          To add one, edit the <code class="font-mono text-xs text-pulse">testimonials</code>
          list at the top of <code class="font-mono text-xs text-pulse">src/pages/outreach.astro</code>
          and set <code class="font-mono text-xs text-pulse">published: true</code>.
        </p>
      </div>
    )}
  </Section>

  <!-- Photo gallery -->
  <Section eyebrow="In the lab" title="Program photos.">
    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 lg:gap-4">
      {galleryPhotos.map((photo, i) => (
        <div class="relative aspect-square bg-ink-800 ring-1 ring-white/5 overflow-hidden group">
          {photo.src ? (
            <img
              src={photo.src}
              alt={photo.alt}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          ) : (
            <div class="absolute inset-0 flex items-center justify-center text-bone-mute">
              <span class="font-mono text-[10px] uppercase tracking-widest2">
                Photo {i + 1}
              </span>
            </div>
          )}
        </div>
      ))}
    </div>
    <p class="mt-6 text-xs text-bone-mute font-mono">
      To add real photos: drop image files into public/outreach/ and update the gallery list at the top of src/pages/outreach.astro.
    </p>
  </Section>

</Base>