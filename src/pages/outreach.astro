---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
---

<Base title="Outreach" description="Outreach and education in the MV Lab, including BRIGHT-UP.">
  <Section
    tight
    eyebrow="Outreach"
    title="Beyond the bench."
    lede="We believe science belongs to everyone. The lab runs and contributes to programs that bring cardiac physiology to students, teachers, and the broader public."
  />

  <Section eyebrow="Featured program" title="BRIGHT-UP">
    <div class="grid lg:grid-cols-12 gap-8 items-start">
      <div class="lg:col-span-7">
        <p class="text-lg text-bone leading-relaxed text-pretty">
          [BRIGHT-UP description — what the program is, who it serves,
          how it runs. Replace this paragraph with the real description
          from your existing site.]
        </p>
        <p class="mt-4 text-base text-bone-dim leading-relaxed">
          [Optional second paragraph: how to apply, partner institutions,
          impact to date.]
        </p>
        <p class="mt-8">
          <a
            href="mailto:mvlab@uw.edu"
            class="inline-block font-mono text-sm uppercase tracking-wider px-6 py-3 border border-pulse text-pulse hover:bg-pulse hover:text-white transition-colors"
          >
            Get involved →
          </a>
        </p>
      </div>
      <div class="lg:col-span-5">
        <!-- Optional: replace with a real photo -->
        <div class="aspect-[4/3] bg-ink-800 ring-1 ring-white/5 flex items-center justify-center text-bone-mute font-mono text-xs">
          BRIGHT-UP photo
        </div>
      </div>
    </div>
  </Section>

  <Section eyebrow="Other engagements" title="Talks, classrooms, and writing.">
    <ul class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      <li>
        <h3 class="font-display text-xl text-bone">Public lectures</h3>
        <p class="mt-3 text-sm text-bone-dim leading-relaxed">
          [Brief description — where you speak, recent talks.]
        </p>
      </li>
      <li>
        <h3 class="font-display text-xl text-bone">K–12 partnerships</h3>
        <p class="mt-3 text-sm text-bone-dim leading-relaxed">
          [Brief description — local schools, summer programs, curricula.]
        </p>
      </li>
      <li>
        <h3 class="font-display text-xl text-bone">Science writing</h3>
        <p class="mt-3 text-sm text-bone-dim leading-relaxed">
          [Popular articles, op-eds, blog posts — link out as needed.]
        </p>
      </li>
    </ul>
  </Section>
</Base>
